{
  "name": "dostonamer",
  "version": "0.1.0",
  "description": "Multilingual pseudonymous username generator",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "dostonamer": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "node --import tsx/esm src/cli/index.ts"
  },
  "files": [
    "dist",
    "packs"
  ],
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
